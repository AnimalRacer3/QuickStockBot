# ─── Web env vars ─────────────────────────────────────────────────────────────
# Copy to .env.local and fill in real values. Never commit .env.local to git.

# Postgres connection string (required)
DATABASE_URL=postgresql://user:password@localhost:5432/quickstockbot

# URL of the Relay HTTP API (used server-side and client-side)
NEXT_PUBLIC_RELAY_API_URL=http://localhost:3001

# URL of the Relay WebSocket endpoint (client-side only)
NEXT_PUBLIC_RELAY_WS_URL=ws://localhost:8080

# Session signing secret — generate with: openssl rand -hex 32
# Must be at least 32 characters
SESSION_SECRET=

# App base URL (used for email verification links)
NEXTAUTH_URL=http://localhost:3000

# ─── Resend (email) ────────────────────────────────────────────────────────────

# Resend API key for sending transactional email
RESEND_API_KEY=

# From address used in emails (must be a verified Resend sender)
RESEND_FROM=noreply@quickstockbot.com

# ─── Stripe ────────────────────────────────────────────────────────────────────

# Stripe secret key (use sk_test_... for test mode)
STRIPE_SECRET_KEY=

# Stripe publishable key (use pk_test_... for test mode)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe Price IDs — create recurring prices in the Stripe test dashboard
# https://dashboard.stripe.com/test/products
# These names must match exactly (Railway reads them verbatim):
STRIPE_PRICE_ID_PREMIUM=
STRIPE_PRICE_ID_BASIC=

# Stripe webhook signing secret (from: stripe listen --print-secret)
STRIPE_WEBHOOK_SECRET=

# ─── Section 12: Licensing ────────────────────────────────────────────────────

# Bot executable download URL — points to the latest GitHub Release zip.
# To pin to a specific version replace "latest/download" with "download/v1.0"
BOT_DOWNLOAD_URL=https://github.com/AnimalRacer3/QuickStockBot/releases/latest/download/QuickStockBot-windows.zip

# SQLite path for the license database (defaults to <cwd>/licenses.db)
LICENSE_DB_PATH=

# Secret key required in X-Admin-Key header to call the revoke endpoint
ADMIN_API_KEY=

# ─── Test helpers (development/testing only) ──────────────────────────────────
# Set to "1" to enable /api/test/* endpoints. Never set in production.
ENABLE_TEST_HELPERS=

# ─── Railway deployment ───────────────────────────────────────────────────────
# Railway injects PORT automatically; Next.js reads it via `npm run start`.
# TLS is terminated at Railway's ingress — no additional TLS config needed here.
# PORT=3000
