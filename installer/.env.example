# ─── Installer env vars ───────────────────────────────────────────────────────
# These are used by the installer wizard; not needed at runtime.

# Target install directory (defaults to ~/.quickstockbot)
INSTALL_DIR=

# GitHub release URL base for downloading binaries
RELEASE_BASE_URL=https://github.com/animalracer3/quickstockbot/releases/latest/download

# Whether to auto-start services after install (true | false)
AUTO_START=true
