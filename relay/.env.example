# ─── Relay env vars ───────────────────────────────────────────────────────────
# Copy to .env and fill in real values. Never commit .env to git.

# Port the Relay WebSocket server listens on
RELAY_PORT=8080

# Port the Relay HTTP API listens on (used by the Web dashboard)
API_PORT=3001

# Secret used to verify bot connection_password_proof (HMAC key)
RELAY_CONNECTION_SECRET=

# JWT secret for signing Web dashboard session tokens
JWT_SECRET=

# Log level (debug | info | warning | error)
LOG_LEVEL=info

# CORS origin for the Web dashboard (leave blank to allow all)
CORS_ORIGIN=http://localhost:3000
