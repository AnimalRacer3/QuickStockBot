# ─── Relay env vars ───────────────────────────────────────────────────────────
# Copy to .env and fill in real values. Never commit .env to git.

# Port the Relay WebSocket server listens on
# Railway injects PORT automatically — use that in production.
RELAY_PORT=8080

# Bind address: "0.0.0.0" for Railway/production, "127.0.0.1" for local-only dev.
# TLS is terminated at Railway's ingress; the relay itself speaks plain WebSocket.
RELAY_HOST=0.0.0.0

# Secret used to verify bot connection_password_proof (HMAC-SHA256 key).
# Must match CONNECTION_PASSWORD set in the bot's .env.
# Generate with: openssl rand -hex 32
RELAY_CONNECTION_SECRET=

# SaaS license validation URL (web dashboard /api/licenses/validate endpoint)
SAAS_VALIDATE_URL=https://app.quickstockbot.com/api/licenses/validate

# Log level (debug | info | warning | error)
LOG_LEVEL=info

# Redis URL for multi-instance relay scaling (optional; in-memory routing used if unset)
# REDIS_URL=redis://localhost:6379
