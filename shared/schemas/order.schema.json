{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://quickstockbot.dev/schemas/order.json",
  "title": "Order",
  "description": "A single order submitted to the broker.",
  "type": "object",
  "required": ["id", "type", "symbol", "qty", "submitted_price", "status"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "description": "Broker-assigned order ID."
    },
    "type": {
      "type": "string",
      "enum": ["buy", "sell", "short", "limit"],
      "description": "Order side/type."
    },
    "symbol": {
      "type": "string",
      "description": "Ticker symbol."
    },
    "qty": {
      "type": "number",
      "minimum": 0,
      "description": "Number of shares (may be fractional)."
    },
    "submitted_price": {
      "type": "number",
      "minimum": 0,
      "description": "Price at the moment the order was submitted (USD)."
    },
    "status": {
      "type": "string",
      "enum": ["pending", "filled", "partial", "cancelled", "rejected"],
      "description": "Current order status."
    },
    "filled_qty": {
      "type": "number",
      "minimum": 0,
      "description": "Shares filled so far."
    },
    "filled_price": {
      "type": "number",
      "minimum": 0,
      "description": "Average fill price (USD); null until at least one fill."
    },
    "submitted_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
