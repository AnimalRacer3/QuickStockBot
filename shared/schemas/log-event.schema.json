{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://quickstockbot.dev/schemas/log-event.json",
  "title": "LogEvent",
  "description": "A structured log entry emitted by the bot.",
  "type": "object",
  "required": ["timestamp", "category", "message"],
  "additionalProperties": false,
  "properties": {
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 UTC timestamp."
    },
    "category": {
      "type": "string",
      "enum": ["info", "warning", "error", "trade", "order", "system"],
      "description": "Log category for filtering in the dashboard."
    },
    "message": {
      "type": "string",
      "description": "Human-readable log message."
    },
    "payload": {
      "type": "object",
      "description": "Arbitrary structured context (ticker, order ID, etc.).",
      "additionalProperties": true
    }
  }
}
