{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://quickstockbot.dev/schemas/trade.json",
  "title": "Trade",
  "description": "A completed round-trip trade: entry order + exit order with realized P/L.",
  "type": "object",
  "required": ["id", "symbol", "entry_order", "exit_order", "net_pl", "label"],
  "additionalProperties": false,
  "definitions": {
    "OrderRef": {
      "type": "object",
      "required": ["id", "type", "symbol", "qty", "submitted_price", "status"],
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["buy", "sell", "short", "limit"] },
        "symbol": { "type": "string" },
        "qty": { "type": "number", "minimum": 0 },
        "submitted_price": { "type": "number", "minimum": 0 },
        "status": { "type": "string", "enum": ["pending", "filled", "partial", "cancelled", "rejected"] },
        "filled_qty": { "type": "number", "minimum": 0 },
        "filled_price": { "type": "number", "minimum": 0 },
        "submitted_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      }
    }
  },
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique trade ID (generated by bot)."
    },
    "symbol": {
      "type": "string"
    },
    "entry_order": {
      "$ref": "#/definitions/OrderRef",
      "description": "The order that opened the position."
    },
    "exit_order": {
      "$ref": "#/definitions/OrderRef",
      "description": "The order that closed the position."
    },
    "net_pl": {
      "type": "number",
      "description": "Realized net profit/loss in USD (negative = loss)."
    },
    "label": {
      "type": "string",
      "enum": ["good", "bad"],
      "description": "Outcome label: good = profitable or within risk tolerance, bad = exceeded stop-loss."
    },
    "opened_at": {
      "type": "string",
      "format": "date-time"
    },
    "closed_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
