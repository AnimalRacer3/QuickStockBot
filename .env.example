# Copy this file to ".env" and place it next to trader.exe. Never commit the real .env.

# Alpaca (data layer) - https://app.alpaca.markets/paper/dashboard/overview
ALPACA_KEY=your_alpaca_key_id_here
ALPACA_SECRET=your_alpaca_secret_key_here

# Anthropic (9:15 ticker-selection call only)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
