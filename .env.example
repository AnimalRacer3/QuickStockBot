# Set to "paper" for paper trading or "live" for live trading.
# The bot refuses to start live without explicit live config.
ALPACA_ENV=paper

# Paper trading credentials (required when ALPACA_ENV=paper)
ALPACA_PAPER_KEY=your-paper-key-here
ALPACA_PAPER_SECRET=your-paper-secret-here

# Live trading credentials (required when ALPACA_ENV=live)
# WARNING: live trading uses real money.
ALPACA_LIVE_KEY=
ALPACA_LIVE_SECRET=
