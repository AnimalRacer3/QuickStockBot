# ─── Bot env vars ─────────────────────────────────────────────────────────────
# Copy to .env and fill in real values. Never commit .env to git.

# Stable UUID identifying this bot instance (generated once at install time)
BOT_ID=

# WebSocket URL of the Relay server
RELAY_URL=wss://relay.example.com

# License key issued at purchase
LICENSE_KEY=

# Shared secret used to authenticate to the Relay (derive proof via HMAC-SHA256)
CONNECTION_PASSWORD=

# ─── Broker (Alpaca) ──────────────────────────────────────────────────────────
BROKER=alpaca
ALPACA_API_KEY=
ALPACA_API_SECRET=
# Set to "true" for paper trading, "false" for live
PAPER_TRADING=true

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ─── Margin / PDT notice ──────────────────────────────────────────────────────
# Post-June 4 2026: PDT $25k minimum has been removed. A $2,000 margin minimum
# applies. Intraday buying power is margin-based. The bot defers to Alpaca's
# reported buying_power and pattern_day_trader flag during the broker phase-in.
# Accounts below 2,000 USD should set PAPER_TRADING=true until confirmed live.
MIN_ACCOUNT_EQUITY_NOTICE=2000
